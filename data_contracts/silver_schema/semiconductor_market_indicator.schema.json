{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "semiconductor_market_indicator",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "indicator_id": { "type": "string", "minLength": 1 },
    "indicator_type": { "const": "market_indicator" },
    "canonical_name": { "type": "string", "minLength": 1 },
    "region": { "type": "string", "minLength": 1 },
    "period": { "type": "string", "minLength": 1 },
    "value": { "type": "number" },
    "unit": { "type": "string", "minLength": 1 },
    "source_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source_ref" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_to": { "type": ["string", "null"], "format": "date-time" },
    "attributes": { "type": "object" }
  },
  "required": ["indicator_id", "indicator_type", "canonical_name", "region", "period", "value", "unit", "source_refs", "confidence", "valid_from", "valid_to"],
  "$defs": {
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_id": { "type": "string" },
        "source_record_id": { "type": "string" },
        "raw_id": { "type": "string" },
        "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "provenance_url": { "type": "string" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "as_of_time": { "type": "string", "format": "date-time" }
      },
      "required": ["source_id", "source_record_id", "raw_id", "payload_hash", "provenance_url", "retrieved_at", "as_of_time"]
    }
  }
}
