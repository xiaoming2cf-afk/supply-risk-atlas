{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "semiconductor_entity",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "entity_id": { "type": "string", "minLength": 1 },
    "entity_type": { "type": "string", "enum": ["company", "country", "region", "facility", "process_stage", "equipment", "material", "chemical", "component", "product_grade", "technology_node", "policy_event", "risk_event", "market_indicator", "trade_flow", "route"] },
    "canonical_name": { "type": "string", "minLength": 1 },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "country_code": { "type": ["string", "null"], "minLength": 2, "maxLength": 2 },
    "sector_tags": { "type": "array", "items": { "type": "string" } },
    "source_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source_ref" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_to": { "type": ["string", "null"], "format": "date-time" },
    "attributes": { "type": "object" }
  },
  "required": ["entity_id", "entity_type", "canonical_name", "aliases", "country_code", "sector_tags", "source_refs", "confidence", "valid_from", "valid_to"],
  "$defs": {
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_id": { "type": "string" },
        "source_record_id": { "type": "string" },
        "raw_id": { "type": "string" },
        "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "provenance_url": { "type": "string" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "as_of_time": { "type": "string", "format": "date-time" }
      },
      "required": ["source_id", "source_record_id", "raw_id", "payload_hash", "provenance_url", "retrieved_at", "as_of_time"]
    }
  }
}
