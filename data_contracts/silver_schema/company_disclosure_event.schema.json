{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "company_disclosure_event",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "const": "risk_event" },
    "canonical_name": { "type": "string", "minLength": 1 },
    "event_time": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1 },
    "affected_entity_ids": { "type": "array", "items": { "type": "string" } },
    "source_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source_ref" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_to": { "type": ["string", "null"], "format": "date-time" },
    "attributes": {
      "type": "object",
      "properties": {
        "company_identifier": { "type": "string" },
        "filing_date": { "type": "string" },
        "disclosure_type": { "type": "string" },
        "supply_chain_keywords": { "type": "array", "items": { "type": "string" } },
        "source_url": { "type": "string" }
      }
    }
  },
  "required": [
    "event_id",
    "event_type",
    "canonical_name",
    "event_time",
    "summary",
    "affected_entity_ids",
    "source_refs",
    "confidence",
    "valid_from",
    "valid_to",
    "attributes"
  ],
  "$defs": {
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_id": { "type": "string" },
        "source_record_id": { "type": "string" },
        "raw_id": { "type": "string" },
        "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "provenance_url": { "type": "string" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "as_of_time": { "type": "string", "format": "date-time" }
      },
      "required": ["source_id", "source_record_id", "raw_id", "payload_hash", "provenance_url", "retrieved_at", "as_of_time"]
    }
  }
}
