{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "trade_tariff_indicator",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "record_type": {
      "const": "trade_tariff_indicator"
    },
    "canonical_name": {
      "type": "string"
    },
    "event_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "location": {
      "type": [
        "object",
        "null"
      ]
    },
    "affected_entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "valid_from": {
      "type": "string",
      "format": "date-time"
    },
    "valid_to": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "evidence_text_summary": {
      "type": "string",
      "minLength": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "record_id",
    "record_type",
    "source_refs",
    "confidence",
    "valid_from",
    "valid_to",
    "evidence_text_summary"
  ]
}
