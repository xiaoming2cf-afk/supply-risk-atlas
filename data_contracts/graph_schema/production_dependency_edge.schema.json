{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "production_dependency_edge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edge_id",
    "relationship_class",
    "edge_type",
    "source_node_id",
    "target_node_id",
    "dependency_source_id",
    "dependency_target_id",
    "dependency_type",
    "criticality",
    "substitutability",
    "bottleneck_flag",
    "propagation_mode_hint",
    "provenance_refs",
    "evidence_text_summary",
    "user_facing_label",
    "confidence",
    "valid_from"
  ],
  "properties": {
    "edge_id": { "type": "string" },
    "relationship_class": { "const": "PRODUCTION_DEPENDENCY" },
    "edge_type": { "enum": ["requires", "depends_on", "uses_equipment", "uses_material", "uses_chemical", "uses_ip", "routes_through", "exposed_to_hazard", "restricted_by", "impacted_by"] },
    "source_node_id": { "type": "string" },
    "target_node_id": { "type": "string" },
    "dependency_source_id": { "type": "string" },
    "dependency_target_id": { "type": "string" },
    "dependency_type": { "type": "string" },
    "criticality": { "type": "number", "minimum": 0, "maximum": 1 },
    "substitutability": { "type": "number", "minimum": 0, "maximum": 1 },
    "bottleneck_flag": { "type": "boolean" },
    "propagation_mode_hint": { "type": "string" },
    "provenance_refs": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "evidence_text_summary": { "type": "string", "maxLength": 1000 },
    "user_facing_label": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "valid_from": { "type": "string" },
    "valid_to": { "type": ["string", "null"] }
  }
}
