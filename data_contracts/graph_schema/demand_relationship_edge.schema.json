{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "demand_relationship_edge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edge_id",
    "relationship_class",
    "edge_type",
    "source_node_id",
    "target_node_id",
    "demand_source_id",
    "product_grade_id",
    "demand_proxy_type",
    "provenance_refs",
    "evidence_text_summary",
    "user_facing_label",
    "confidence",
    "valid_from"
  ],
  "properties": {
    "edge_id": { "type": "string" },
    "relationship_class": { "const": "DEMAND_RELATIONSHIP" },
    "edge_type": { "enum": ["demands", "demand_signal_for", "used_in_downstream_sector", "serves_downstream_sector", "demand_shock_on"] },
    "source_node_id": { "type": "string" },
    "target_node_id": { "type": "string" },
    "demand_source_id": { "type": "string" },
    "product_grade_id": { "type": "string" },
    "region": { "type": ["string", "null"] },
    "period": { "type": ["string", "null"] },
    "demand_proxy_type": { "type": "string" },
    "demand_value": { "type": ["number", "null"] },
    "demand_growth_proxy": { "type": ["number", "null"] },
    "provenance_refs": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "evidence_text_summary": { "type": "string", "maxLength": 1000 },
    "user_facing_label": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "valid_from": { "type": "string" },
    "valid_to": { "type": ["string", "null"] }
  }
}
