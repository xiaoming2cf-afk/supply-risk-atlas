{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "semirisk_edge",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "edge_id": { "type": "string", "minLength": 1 },
    "source_node_id": { "type": "string", "minLength": 1 },
    "target_node_id": { "type": "string", "minLength": 1 },
    "edge_type": { "type": "string", "enum": ["participates_in", "located_in", "requires", "produces", "supplies", "depends_on", "substitutable_with", "restricted_by", "impacted_by", "exports_to", "imports_from", "routes_through", "correlated_with", "evidence_for"] },
    "weight": { "type": "number", "minimum": 0 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "valid_from": { "type": "string", "format": "date-time" },
    "valid_to": { "type": ["string", "null"], "format": "date-time" },
    "provenance_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source_ref" } },
    "evidence_text_summary": { "type": "string", "minLength": 1 },
    "attributes": { "type": "object" }
  },
  "required": ["edge_id", "source_node_id", "target_node_id", "edge_type", "weight", "confidence", "valid_from", "valid_to", "provenance_refs", "evidence_text_summary"],
  "$defs": {
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_id": { "type": "string" },
        "source_record_id": { "type": "string" },
        "raw_id": { "type": "string" },
        "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "provenance_url": { "type": "string" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "as_of_time": { "type": "string", "format": "date-time" }
      },
      "required": ["source_id", "source_record_id", "raw_id", "payload_hash", "provenance_url", "retrieved_at", "as_of_time"]
    }
  }
}
