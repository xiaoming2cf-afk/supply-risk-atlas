{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mineral_dependency_edge",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "edge_id": {"type": "string", "minLength": 1},
    "source_node_id": {"type": "string", "minLength": 1},
    "target_node_id": {"type": "string", "minLength": 1},
    "edge_type": {"const": "mineral_dependency_edge"},
    "user_facing_label": {"const": "mineral_dependency_edge"},
    "weight": {"type": "number"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "evidence_text_summary": {"type": "string", "minLength": 1},
    "valid_from": {"type": "string", "format": "date-time"},
    "valid_to": {"type": ["string", "null"], "format": "date-time"},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "attributes": {"type": "object"}
  },
  "required": [
    "edge_id",
    "source_node_id",
    "target_node_id",
    "edge_type",
    "user_facing_label",
    "confidence",
    "provenance_refs",
    "evidence_text_summary",
    "valid_from",
    "valid_to"
  ]
}
