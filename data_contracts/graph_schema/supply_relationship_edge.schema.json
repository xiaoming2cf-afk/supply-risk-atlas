{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "supply_relationship_edge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edge_id",
    "relationship_class",
    "edge_type",
    "source_node_id",
    "target_node_id",
    "supplier_id",
    "supplied_item_id",
    "supplied_item_type",
    "relationship_scope",
    "provenance_refs",
    "evidence_text_summary",
    "user_facing_label",
    "confidence",
    "valid_from"
  ],
  "properties": {
    "edge_id": { "type": "string" },
    "relationship_class": { "const": "SUPPLY_RELATIONSHIP" },
    "edge_type": { "enum": ["supplies", "supplies_item", "provides_equipment", "provides_material", "provides_chemical", "provides_ip", "provides_service", "provides_capacity", "packaged_by", "tested_by", "manufactured_by"] },
    "source_node_id": { "type": "string" },
    "target_node_id": { "type": "string" },
    "supplier_id": { "type": "string" },
    "buyer_or_stage_id": { "type": ["string", "null"] },
    "supplied_item_id": { "type": "string" },
    "supplied_item_type": { "type": "string" },
    "relationship_scope": { "type": "string" },
    "share_or_capacity_proxy": { "type": ["number", "null"], "minimum": 0 },
    "lead_time_days": { "type": ["number", "null"], "minimum": 0 },
    "qualification_time_days": { "type": ["number", "null"], "minimum": 0 },
    "substitution_available": { "type": ["boolean", "null"] },
    "provenance_refs": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "evidence_text_summary": { "type": "string", "maxLength": 1000 },
    "user_facing_label": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "valid_from": { "type": "string" },
    "valid_to": { "type": ["string", "null"] }
  }
}
