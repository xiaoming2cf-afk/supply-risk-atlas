{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "oecd_semiconductor_value_chain_raw",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source_id": {"enum": ["oecd_semiconductor_value_chain_reports"]},
    "source_record_id": {"type": "string", "minLength": 1},
    "retrieved_at": {"type": "string", "format": "date-time"},
    "as_of_time": {"type": "string", "format": "date-time"},
    "payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "provenance_url": {"type": "string", "minLength": 1},
    "raw_payload_summary": {"type": "string", "minLength": 1},
    "license_or_terms_ref": {"type": "string", "minLength": 1},
    "report_title": {"type": "string"},
    "report_section": {"type": ["string", "null"]},
    "value_chain_stage": {"type": ["string", "null"]},
    "methodology_summary": {"type": ["string", "null"]}
  },
  "required": [
    "source_id",
    "source_record_id",
    "retrieved_at",
    "as_of_time",
    "payload_hash",
    "provenance_url",
    "raw_payload_summary",
    "license_or_terms_ref"
  ]
}
