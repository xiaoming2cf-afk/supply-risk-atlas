{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "gta_export_controls_raw",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "source_id": { "const": "global_trade_alert_semiconductor_export_controls" },
    "source_record_id": { "type": "string", "minLength": 1 },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "source_published_at": { "type": ["string", "null"], "format": "date-time" },
    "as_of_time": { "type": "string", "format": "date-time" },
    "payload_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "provenance_url": { "type": "string", "minLength": 1 },
    "raw_payload_summary": { "type": "string", "minLength": 1 },
    "license_or_terms_ref": { "type": "string", "minLength": 1 }
  },
  "required": ["source_id", "source_record_id", "retrieved_at", "source_published_at", "as_of_time", "payload_hash", "provenance_url", "raw_payload_summary", "license_or_terms_ref"]
}
