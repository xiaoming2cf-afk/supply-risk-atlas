{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "semiconductor_source_registry",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "registry_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "source_id": {
            "type": "string",
            "enum": [
              "eto_cset_advanced_semiconductor_supply_chain",
              "wsts_historical_billings",
              "global_trade_alert_semiconductor_export_controls",
              "gdelt_semiconductor_events",
              "sec_edgar_lite",
              "gdelt_semiconductor_lite",
              "un_comtrade_semiconductor_trade_lite",
              "world_bank_wits_trade_tariff_lite",
              "usgs_earthquake_lite",
              "nga_world_port_index_lite",
              "ofac_sanctions_list_lite",
              "bis_export_controls_lite",
              "federal_register_export_controls_lite",
              "world_bank_macro_indicators_lite",
              "ourairports_lite",
              "openalex_crossref_literature_lite",
              "company_annual_report_manual_upload",
              "customs_trade_manual_upload",
              "paid_semi_market_data",
              "proprietary_factset_supply_chain",
              "bloomberg_supply_chain",
              "wind_or_choice_private_data",
              "company_private_order_data"
            ]
          },
          "publisher": { "type": "string", "minLength": 1 },
          "source_url": { "type": "string", "minLength": 1 },
          "terms_url": { "type": "string", "minLength": 1 },
          "license_or_terms_summary": { "type": "string", "minLength": 1 },
          "allowed_use": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "redistribution_limits": { "type": "string", "minLength": 1 },
          "attribution": { "type": "string", "minLength": 1 },
          "requires_api_key": { "type": "boolean" },
          "enabled_by_default": { "type": "boolean" },
          "live_fetch_default": { "type": "boolean" },
          "update_frequency": {
            "type": "string",
            "enum": ["15_minutes", "hourly", "daily", "weekly", "monthly", "irregular"]
          },
          "freshness_sla_hours": { "type": "integer", "minimum": 1 },
          "connector": { "type": "string", "minLength": 1 },
          "raw_contract": { "type": "string", "minLength": 1 },
          "silver_contract": { "type": "string", "minLength": 1 },
          "graph_contract": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "review_status": { "type": "string", "minLength": 1 },
          "source_tier": {
            "type": "string",
            "enum": ["tier_0", "tier_1", "tier_2", "tier_3"]
          },
          "data_category": {
            "type": "string",
            "enum": [
              "supply_chain_structure",
              "market_indicator",
              "trade_flow",
              "policy_export_control",
              "sanctions_compliance",
              "event_news",
              "natural_hazard",
              "logistics",
              "literature_methodology",
              "manual_upload"
            ]
          },
          "pii_risk": { "type": "string", "minLength": 1 },
          "raw_payload_storage_policy": {
            "type": "string",
            "enum": ["hash_and_summary_only", "registry_only", "manual_review_required"]
          },
          "api_visibility_policy": {
            "type": "string",
            "enum": ["summary_and_lineage_only", "summary_only", "metadata_only", "registry_only"]
          }
        },
        "required": [
          "source_id",
          "publisher",
          "source_url",
          "terms_url",
          "license_or_terms_summary",
          "allowed_use",
          "redistribution_limits",
          "attribution",
          "requires_api_key",
          "enabled_by_default",
          "live_fetch_default",
          "update_frequency",
          "freshness_sla_hours",
          "connector",
          "raw_contract",
          "silver_contract",
          "graph_contract",
          "owner",
          "review_status",
          "source_tier",
          "data_category",
          "pii_risk",
          "raw_payload_storage_policy",
          "api_visibility_policy"
        ]
      }
    }
  },
  "required": ["registry_version", "generated_at", "sources"]
}
