{
  "$defs": {
    "GeoPoint": {
      "additionalProperties": false,
      "properties": {
        "latitude": {
          "maximum": 90.0,
          "minimum": -90.0,
          "title": "Latitude",
          "type": "number"
        },
        "longitude": {
          "maximum": 180.0,
          "minimum": -180.0,
          "title": "Longitude",
          "type": "number"
        }
      },
      "required": [
        "latitude",
        "longitude"
      ],
      "title": "GeoPoint",
      "type": "object"
    },
    "SilverEventEntityRef": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "title": "Entity Id",
          "type": "string"
        },
        "role": {
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "entity_id",
        "role"
      ],
      "title": "SilverEventEntityRef",
      "type": "object"
    },
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "raw_id": {
          "title": "Raw Id",
          "type": "string"
        },
        "source_record_id": {
          "title": "Source Record Id",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "raw_id",
        "source_record_id"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "event_type": {
      "title": "Event Type",
      "type": "string"
    },
    "source_refs": {
      "items": {
        "$ref": "#/$defs/SourceReference"
      },
      "title": "Source Refs",
      "type": "array"
    },
    "event_time": {
      "format": "date-time",
      "title": "Event Time",
      "type": "string"
    },
    "published_time": {
      "format": "date-time",
      "title": "Published Time",
      "type": "string"
    },
    "observed_time": {
      "format": "date-time",
      "title": "Observed Time",
      "type": "string"
    },
    "ingest_time": {
      "format": "date-time",
      "title": "Ingest Time",
      "type": "string"
    },
    "entities": {
      "items": {
        "$ref": "#/$defs/SilverEventEntityRef"
      },
      "title": "Entities",
      "type": "array"
    },
    "location": {
      "anyOf": [
        {
          "$ref": "#/$defs/GeoPoint"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "attributes": {
      "additionalProperties": true,
      "title": "Attributes",
      "type": "object"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "schema_version": {
      "default": "silver-event-v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "event_type",
    "source_refs",
    "event_time",
    "published_time",
    "observed_time",
    "ingest_time",
    "confidence"
  ],
  "title": "SilverEvent",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
