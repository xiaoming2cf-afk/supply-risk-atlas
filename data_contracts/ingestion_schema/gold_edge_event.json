{
  "$defs": {
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "raw_id": {
          "title": "Raw Id",
          "type": "string"
        },
        "source_record_id": {
          "title": "Source Record Id",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "raw_id",
        "source_record_id"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
